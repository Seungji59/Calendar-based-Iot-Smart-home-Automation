        "func": "// msg.payload.d.trip: \"trip\" 또는 \"untrip\"이 들어온다고 가정\nif (msg.payload && msg.payload.d && msg.payload.d.trip) {\n    global.set(\"tripState\", msg.payload.d.trip);\n    //node.warn(\"Trip 상태를 global로 저장: \" + msg.payload.d.trip);\n}\nreturn msg;  // 필요하면 다음 노드로 전달, 아니면 null 가능\n",
