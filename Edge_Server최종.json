    {
        "id": "25ee795ea635af53",
        "type": "function",
        "z": "d45ec001c84d7414",
        "name": "전등 switch",
        "func": "// switch_lamp 상태 확인\nlet currButton = global.get(\"currButton\");\n\n\nif (currButton === \"off\") {\n    // switch 값을 읽음\n    let sw = msg.payload.d.switch;  // \"on\" 또는 \"off\"\n\n    // lamp에 switch 값을 그대로 전달\n    msg.payload = {\n        d: {\n            lamp: sw\n        }\n    };\n    global.set(\"lamp\", sw);\n}\nelse {\n    // 버튼이 on이면 lamp를 강제 off\n    msg.payload = {\n        d: {\n            lamp: \"off\"\n        }\n    };\n    global.set(\"lamp\", \"off\");\n}\n\nreturn msg;\n",
