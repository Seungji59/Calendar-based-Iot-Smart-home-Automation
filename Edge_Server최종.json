    {
        "id": "e8ef82cbf87e164b",
        "type": "function",
        "z": "d45ec001c84d7414",
        "name": "automate",
        "func": "// global에서 trip 상태 읽기\nlet tripState = global.get(\"tripState\") || \"untrip\"; //Trip 상태가 아직 설정되지 않은 경우에도 안전하게 \"untrip\"으로 초기화\n\nglobal.set(\"target\", msg.payload.d.target);\n\n// 1) 여행 중이면 자동 밸브 제어 중단\nif (tripState === \"trip\") {\n    //node.warn(\"Trip 상태 → 온도 자동제어 중단. 밸브를 변경하지 않음.\");\n    return null;   // 메시지 전달 X\n}\nelse{\n    // 2) 여행 중이 아니면 기존 온도 제어 로직 실행\n    let evt1 = { d: {} };\n\n    if (msg.payload.d.target > msg.payload.d.temperature) {\n        evt1.d.valve = 'on';\n    } else {\n        evt1.d.valve = 'off';\n    }\n\n    return { payload: evt1 };\n}\n\n",
        "outputs": 1,
