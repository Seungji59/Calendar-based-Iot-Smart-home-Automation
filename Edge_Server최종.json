    {
        "id": "9a4839bb3054f1a6",
        "type": "function",
        "z": "d45ec001c84d7414",
        "name": "외출 button",
        "func": "/*\nlet out1 = null;\nlet out2 = null;\n\n// 🔹 global에 저장된 target 값 가져오기 (없으면 0으로)\nlet savedTarget = global.get(\"target\");\nif (savedTarget === undefined) savedTarget = 0;\n\n// 🔸 이전 버튼 상태 가져오기 → flow context 사용\nlet prevButton = flow.get(\"prevButton\");\nlet currButton = msg.payload.d.button;\n\n\n\n// 🔸 버튼 변화가 없다면 → target 변경 없음\nif (prevButton === currButton) {\n    if (currButton === 'on') {\n        out1 = { payload: { d: { lamp: \"on\" } } };\n    } else if (currButton === 'off') {\n        out1 = { payload: { d: { lamp: \"off\" } } };\n    }\n    // ⭐ currButton 글로벌로 저장\n    global.set(\"currButton\", currButton);\n\n    return [out1, null];\n}\n\n// 🔸 버튼이 변화한 순간에만 target 변경\nif (currButton === 'on') {\n    // out1 = { payload: { d: { lamp: \"off\" } } };\n    savedTarget -= 2;\n    global.set(\"currButton\", currButton);\n}\n\nif (currButton === 'off') {\n    // out1 = { payload: { d: { lamp: \"on\" } } };\n    savedTarget += 2;\n}\n\n// 🔸 변경된 target은 global에 저장\nglobal.set(\"target\", savedTarget);\n\n// 🔸 버튼 상태는 flow에 저장\nflow.set(\"prevButton\", currButton);\n\n// 🔸 ESP32로 target 전달\nout2 = {\n    payload: {\n        d: { target: savedTarget }\n    }\n};\n\nreturn [out1, out2];\n*/\n\nlet out1 = null;\nlet out2 = null;\n\nlet saved_light=global.get(\"lamp\");\n\n// 🔹 global에 저장된 target 값 가져오기 (없으면 0으로)\nlet savedTarget = global.get(\"target\");\nif (savedTarget === undefined) savedTarget = 0;\n\n// 🔸 이전 버튼 상태 가져오기 → flow context 사용\nlet prevButton = flow.get(\"prevButton\");\nlet currButton = msg.payload.d.button;\n\n// 🔸 버튼이 변화한 순간에만 target 변경\nif (currButton === 'on') {\n    savedTarget -= 2;\n    out1 = { payload: { d: { lamp: \"off\" } } };\n}\n\nif (currButton === 'off') {\n    savedTarget += 2;\n    out1 = { payload: { d: { lamp: saved_light } } };\n}\n\n// ⭐ currButton을 global 저장 (on/off 모두!)\nglobal.set(\"currButton\", currButton);\n\n// 🔸 변경된 target은 global에 저장\nglobal.set(\"target\", savedTarget);\n\n// 🔸 버튼 상태는 flow에 저장\nflow.set(\"prevButton\", currButton);\n\n// 🔸 ESP32로 target 전달\nout2 = {\n    payload: {\n        d: { target: savedTarget }\n    }\n};\n\nreturn [out1, out2];\n\n",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
